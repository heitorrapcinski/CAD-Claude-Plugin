{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/build/hooks/protect-human-validation.cjs"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/build/hooks/technique-isolation.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/build/hooks/validate-evidence.cjs"
          }
        ]
      }
    ]
  }
}
